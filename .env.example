# Cluster configuration
CLUSTER_PEERS=localhost:8889,localhost:8890
CLUSTER_PORT=9000
CLUSTER_LISTEN_ADDR=[::1]

# Hide actual cluster peer IP addresses in responses (use node$i instead)
# If true, responses will show "node0", "node1", etc instead of actual IPs
CLUSTER_HIDE_IP=false

# IP Whitelisting (comma-separated, supports exact IPs and CIDR subnets)
# Examples: 127.0.0.1, ::1, 192.168.0.0/16, 192.168.1.0/24, 0.0.0.0/0 (any IPv4), ::/0 (any IPv6)
# Leave empty to allow all IPs
HTTP_WHITELIST_READ=0.0.0.0/0,::/0,127.0.0.1,::1
HTTP_WHITELIST_WRITE=0.0.0.0/0,::/0,127.0.0.1,::1
CLUSTER_WHITELIST_IPS=0.0.0.0/0,::/0,127.0.0.1,::1

# Security: AES-256 encryption key (32 bytes in base64 or raw)
# Generate with: openssl rand -base64 32
CLUSTER_CIPHER_KEY=dGhpcyBpcyBhIDMyIGJ5dGUga2V5IGZvciBBRVMtMjU2IQ==

# Security: Shared peer secret for authentication
CLUSTER_PEER_SECRET=your-shared-secret-here-change-this

# Copy this file to .env and adjust as needed.

# HTTP server configuration
HTTP_ENABLED=true
HTTP_PORT=8888
HTTP_LISTEN_ADDR=0.0.0.0

# Control whether public arrays are readable without authentication
# If true, anyone can read public data without keys
# If false, reads require &http_read_key=<HTTP_READ_KEY>
HTTP_PUBLIC=true

# Authentication keys for public array operations
# HTTP_READ_KEY required if HTTP_PUBLIC=false
# HTTP_WRITE_KEY required for all write/delete operations on public arrays
HTTP_READ_KEY=change-this-http-read-key
HTTP_WRITE_KEY=change-this-http-write-key

# Control whether HTTP/CURL write operations are allowed
# If false, HTTP POST/DELETE will be rejected (requires HTTP_WRITE_KEY anyway)
# TCP and WebSocket write operations have separate controls
HTTP_ALLOW_WRITE=true

# HTTPS server configuration
HTTPS_ENABLED=false
HTTPS_PORT=8443
HTTPS_LISTEN_ADDR=0.0.0.0
HTTPS_CERT_FILE=
HTTPS_KEY_FILE=

# Optional virtual host restriction (comma-separated hostnames/IPs).
# If empty and HTTPS is enabled, domains are auto-detected from certificate SAN/CN.
LISTEN_DOMAINS=

# WebSocket configuration
WS_ENABLED=true

# Logging configuration
LOG_ENABLED=false
LOG_PATH=system.log

# Authentication for private arrays
# These credentials are required to access private arrays via HTTP (Basic Auth) or TCP
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# TCP protocol configuration (direct cluster communication)
TCP_ENABLED=true
TCP_PORT=9001
TCP_LISTEN_ADDR=0.0.0.0
TCP_KEY=your-tcp-key-here-change-this
TCP_WHITELIST_IPS=0.0.0.0/0,::/0,127.0.0.1,::1
TCP_TIMEOUT=30
