# tcpclusterd Configuration File
# Copy this to .env and customize for your deployment

# ==========================================
# Cluster Configuration
# ==========================================
# Single server: leave empty
# Multi-server: comma-separated peer addresses
# Example: CLUSTER_PEERS=[2a03:94e0:205b:d:1::aaaa]:5000,[2a03:94e0:205b:d:1::aaab]:5000
CLUSTER_PEERS=

# Default replication port (5000 is standard)
CLUSTER_DEFAULT_PORT=5000

# Secret token for cluster replication (required for multi-server)
# Generate: openssl rand -base64 32
REPLICATION_TOKEN=

# ==========================================
# Authentication & Security
# ==========================================
# Admin password for initial setup
ADMIN_PASSWORD=admin

# AES encryption key for JWT tokens (32 characters)
# Generate: openssl rand -base64 32
AES_KEY=default-secret-key-for-jwt-tokens

# ==========================================
# Runtime & Storage
# ==========================================
# Directory for runtime snapshots (one per session)
RUNTIME_PATH=runtime

# Directory for persistent backups
PERSISTENT_BACKUP_PATH=backups

# Auto-backup database on shutdown
AUTO_BACKUP=true

# Auto-clear old runtime folders on startup
AUTO_CLEAR_RUNTIMES=false

# ==========================================
# Token Management
# ==========================================
# Token TTL in seconds (empty = tokens never expire)
# Set to 3600 for 1 hour expiration
TOKEN_TTL_SECONDS=

# ==========================================
# Logging
# ==========================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log output file (empty = stdout only)
LOG_FILE=logs/app.log

# Audit log file (empty = disabled)
AUDIT_LOG_FILE=logs/audit.log
# ==========================================
# Replication Configuration
# ==========================================
# Comma-separated list of peer servers to replicate to
# Format: host1:port1,host2:port2,host3:port3
# Leave empty to disable replication
REPLICATION_PEERS=

# Optional shared token used to authenticate /api/replicate requests between nodes.
# Set the same value on all peers in the cluster.
REPLICATION_TOKEN=

# ==========================================
# Advanced Configuration
# ==========================================
# Maximum number of replication retries
MAX_REPLICATION_RETRIES=3

# Replication retry delay in milliseconds
REPLICATION_RETRY_DELAY=1000

# Database auto-save interval in seconds
AUTOSAVE_INTERVAL=30

# HTTPS server configuration
HTTPS_ENABLED=false
HTTPS_PORT=8443
HTTPS_LISTEN_ADDR=0.0.0.0
HTTPS_CERT_FILE=
HTTPS_KEY_FILE=

# Optional virtual host restriction (comma-separated hostnames/IPs).
# If empty and HTTPS is enabled, domains are auto-detected from certificate SAN/CN.
LISTEN_DOMAINS=

# WebSocket configuration
WS_ENABLED=true

# Logging configuration
LOG_ENABLED=false
LOG_PATH=system.log

# Local control socket for internal CLI -> running server commands
# Used by commands like --export, --import, --importfile, --recover when server is already running.
# No protocol-level auth; access is controlled by local filesystem permissions on the socket file.
CONTROL_SOCKET=/tmp/tcpclusterd.sock

# Authentication for private arrays
# These credentials are required to access private arrays via HTTP (Basic Auth) or TCP
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Optional auth token TTL (seconds). Expired tokens are periodically deleted from system.tokens.
# Set to 0 or leave empty to disable TTL-based cleanup.
TOKEN_TTL_SECONDS=

# TCP protocol configuration (direct cluster communication)
TCP_ENABLED=true
TCP_PORT=9001
TCP_LISTEN_ADDR=0.0.0.0
TCP_KEY=your-tcp-key-here-change-this
TCP_WHITELIST_IPS=0.0.0.0/0,::/0,127.0.0.1,::1
TCP_TIMEOUT=30
