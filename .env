# Cluster peers (comma-separated, identical on all servers)
# Each server auto-identifies by trying to bind to each address
CLUSTER_PEERS=127.0.0.1:5000,192.168.1.100:5000,192.168.1.101:5000
CLUSTER_DEFAULT_PORT=5000

# Admin password for initial setup
ADMIN_PASSWORD=admin

# Logging configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log
AUDIT_LOG_FILE=logs/audit.log

# NOTE: Port and Host are NOT configured here!
# Services (HTTP, TCP, WebSocket) are configured via database:
#   ./app --config-http "enabled=true port=9090 host=0.0.0.0"
#   ./app --config-tcp "enabled=true port=5000 host=0.0.0.0"
#   ./app --config-ws "enabled=true port=8080 host=0.0.0.0"
